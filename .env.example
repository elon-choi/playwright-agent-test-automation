# 이 프로젝트 전용 환경 변수. .env로 복사한 뒤 값만 채운다.

# 로그인 시나리오용 (선택). BASE_URL, 슬랙 등
# BASE_URL=https://page.kakao.com/
# SLACK_WEBHOOK_URL=

# 테스트용 고정 작품. 메인->작품 진입 시 랜덤 클릭 대신 여기서 선택해 이동 (안정성)
# 미설정 시 메인 첫 번째 작품 링크를 클릭하므로, 뷰어 시나리오(109/112/113 등)에서는 테스트 풀 제어를 위해 설정 권장.
# 단일: TEST_WORK_URL=https://page.kakao.com/content/123
# 복수(쉼표 구분, 그중 랜덤 1개). 개미(68239972) 제거, 아래 2작품 사용:
TEST_WORK_URLS=https://page.kakao.com/content/59782511,https://page.kakao.com/content/54498159
# TEST_WORK_URL=

# Google Sheets ↔ BDD 동기화 (sync:pull / sync:push)
# SPREADSHEET_ID=   # 스프레드시트 URL의 /d/ 여기부분 /edit
# SHEET_NAME=테스트케이스
# SHEET_COLUMN_TC_ID=1
# SHEET_COLUMN_PRECONDITION=2
# SHEET_COLUMN_STEPS=3
# SHEET_COLUMN_EXPECTED=4
# SHEET_DATA_START_ROW=2
# Google 인증: (1) 이메일+비밀키 또는 (2) JSON 파일 경로 중 하나만 설정
# (1) 보안 담당자 제공 양식 사용 시:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# (2) JSON 파일 사용 시:
# GOOGLE_APPLICATION_CREDENTIALS=./config/gcp-service-account.json

# OpenAI (동기화 시 Gherkin/JSON 번역)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
