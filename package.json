{
  "name": "playwright-agent-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pw:install": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright install",
    "test": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test",
    "bddgen": "node scripts/run-bddgen.mjs",
    "test:ui": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test --ui --project=chromium",
    "last-failure": "npx ts-node --esm scripts/last-failure.ts",
    "notify-slack": "node scripts/notify-slack.mjs",
    "test:ci": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test; e=$?; TEST_EXIT_CODE=$e npm run notify-slack; exit $e",
    "test:ui:ci": "rm -rf allure-results; PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test --ui --project=chromium; e=$?; npx allure generate allure-results -o allure-report --clean 2>/dev/null; TEST_EXIT_CODE=$e npm run notify-slack; node scripts/publish-local-report.mjs; exit $e",
    "test:headless": "rm -rf allure-results; CI=true PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test --project=chromium; e=$?; npx allure generate allure-results -o allure-report --clean 2>/dev/null; TEST_EXIT_CODE=$e npm run notify-slack; node scripts/publish-local-report.mjs; exit $e",
    "overnight": "node scripts/overnight-generate-remaining.mjs",
    "clean:dumps": "node scripts/clean-old-dumps.mjs 1",
    "clean:allure-results": "node scripts/clean-allure-results.mjs --older-than 1",
    "clean:retention-1d": "node scripts/clean-old-dumps.mjs 1 && node scripts/clean-allure-results.mjs --older-than 1",
    "clean:results": "node scripts/clean-all-results.mjs",
    "publish:local-report": "node scripts/publish-local-report.mjs",
    "test:ui:demo": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test --ui --project=chromium",
    "test:ui:remaining": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test --ui --project=chromium-remaining",
    "test:ui:stub": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test --ui --project=chromium-remaining",
    "test:ui:085": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test .features-gen/features/pcw/06-콘텐츠홈/kpa-085.feature.spec.js --ui --project=chromium-085",
    "test:085": "node scripts/run-kpa-085.mjs",
    "test:085:ui": "node scripts/run-kpa-085.mjs --ui",
    "test:085:10": "node scripts/run-kpa-085.mjs --repeat-each=10",
    "verify:085": "node scripts/verify-kpa-085-steps.mjs",
    "test:ui:116": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 playwright test .features-gen/features/pcw/07-뷰어/kpa-116.feature.spec.js --ui --project=chromium --repeat-each=10",
    "test:failed12": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 CI=true playwright test --grep \"KPA-(070|071|073|074|032|066|093|107|112|127|085)\" --project=chromium --project=chromium-mw",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:serve": "allure serve allure-results",
    "sync:pull": "npx ts-node --esm scripts/sync-pull.ts",
    "sync:push": "npx ts-node --esm scripts/sync-push.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.58.1",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.4.5",
"dotenv": "latest",
    "playwright-bdd": "^8.4.2",
    "ts-node": "^10.9.2",
    "typescript": "latest"
  },
  "dependencies": {
    "googleapis": "^144.0.0"
  }
}